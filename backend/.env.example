DATABASE_URL=postgres://USER:PASSWORD@HOST/db?sslmode=require
FRONTEND_URL=http://localhost:5173
PORT=4000

# Clay enrichment (required only when running real enrichment)
CLAY_WEBHOOK_URL=https://app.clay.com/webhook/...
CLAY_WEBHOOK_AUTH=...
CLAY_CALLBACK_SECRET=dev-secret

# Set to any truthy value ("1", "true") to bypass real Clay and use the
# in-process mock provider — exercises every error bucket without burning
# Clay credits. Leave empty in production.
CLAY_MOCK_MODE=

# Resilient enrichment knobs (all optional, defaults shown)
ENRICH_DISPATCH_TIMEOUT_MS=30000
ENRICH_MAX_ATTEMPTS=5
ENRICH_WORKER_INTERVAL_MS=3000
ENRICH_CALLBACK_TIMEOUT_SECONDS=900
ENRICH_DISPATCH_CONCURRENCY=20
